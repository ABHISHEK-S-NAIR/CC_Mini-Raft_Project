{
  "name": "cc-mini-project-mini-raft",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "services/*",
    "dashboard"
  ],
  "scripts": {
    "dev:gateway": "npm run dev -w @mini-raft/gateway",
    "dev:replica": "npm run dev -w @mini-raft/replica",
    "dev:dashboard": "npm run dev -w @mini-raft/dashboard",
    "build": "npm run build --workspaces",
    "typecheck": "npm run typecheck --workspaces"
  }
}
