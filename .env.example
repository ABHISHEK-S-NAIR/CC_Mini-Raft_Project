# Copy this file to .env and adjust values for your environment.
# Defaults mirror current docker-compose behavior.

# Host and container ports
GATEWAY_HOST_PORT=3000
GATEWAY_PORT=3000
DASHBOARD_HOST_PORT=3001
DASHBOARD_PORT=3001
REPLICA1_HOST_PORT=4001
REPLICA1_PORT=4001
REPLICA2_HOST_PORT=4002
REPLICA2_PORT=4002
REPLICA3_HOST_PORT=4003
REPLICA3_PORT=4003

# Service routing
REPLICA_MAP=replica1=http://replica1:4001,replica2=http://replica2:4002,replica3=http://replica3:4003
REPLICA_URLS=http://gateway:3000,http://replica1:4001,http://replica2:4002,http://replica3:4003
REPLICA_GATEWAY_URL=http://gateway:3000

# Replica identities and peer maps
REPLICA1_ID=replica1
REPLICA1_PEERS=replica2=http://replica2:4002,replica3=http://replica3:4003
REPLICA2_ID=replica2
REPLICA2_PEERS=replica1=http://replica1:4001,replica3=http://replica3:4003
REPLICA3_ID=replica3
REPLICA3_PEERS=replica1=http://replica1:4001,replica2=http://replica2:4002

# RAFT timing and gateway notify retry controls
HEARTBEAT_INTERVAL_MS=150
ELECTION_TIMEOUT_MIN_MS=500
ELECTION_TIMEOUT_MAX_MS=800
HEARTBEAT_LOG_INTERVAL_MS=4000
GATEWAY_NOTIFY_TIMEOUT_MS=1000
GATEWAY_NOTIFY_MAX_ATTEMPTS=10
GATEWAY_NOTIFY_RETRY_DELAY_MS=500
